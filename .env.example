# ============================================
# NexRadar Pro - Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to GitHub!

# ============================================
# Polygon.io API (Market Data)
# ============================================
# Get your free API key at: https://polygon.io/
# Free tier: 5 requests/minute
MASSIVE_API_KEY=your_polygon_api_key_here

# ============================================
# Supabase (Database)
# ============================================
# Get these from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ============================================
# Frontend Configuration
# ============================================
# URL where your frontend will be deployed
# For local development, use http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173
