# ============================================
# NexRadar Pro - Git Ignore Configuration
# ============================================

# ============================================
# CRITICAL: Never commit these files!
# ============================================
.env
.env.local
.env.production
.env.development
config.env
*service_key*
*api_key*
*secret*
*.pem
*.key

